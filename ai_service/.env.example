# Copy this file to .env and fill in real values.

# MongoDB (use the same URI as the Node.js server)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/dentacare?appName=Cluster0

# Gemini API keys
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=
GEMINI_API_KEY_4=
GEMINI_API_KEY_5=
GEMINI_CHAT_MODELS=gemini-2.5-flash,gemini-2.0-flash
GEMINI_EMBEDDING_MODEL=embedding-001

# MongoDB Atlas Vector Search
ATLAS_VECTOR_INDEX=knowledge_vector_index
ATLAS_VECTOR_PATH=embedding
ATLAS_VECTOR_CANDIDATES=100

# RAG config
RAG_TOP_K=10
RAG_MIN_SCORE=0
RAG_RERANK_ENABLED=true
RAG_VECTOR_WEIGHT=0.7
RAG_KEYWORD_WEIGHT=0.3

# Service port
PORT=8000
