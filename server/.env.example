PORT=5002
NODE_ENV=development
LOG_LEVEL=info
AUTH_RATE_LIMIT_WINDOW_MINUTES=1
AUTH_RATE_LIMIT_MAX=100

# ── AI Service (Python FastAPI, port 8000) ────────────────────────────────────
# FastAPI AI service started automatically by the Node backend
AI_SERVICE_ENABLED=true
AI_SERVICE_REQUIRED=false
AI_SERVICE_HOST=127.0.0.1
AI_SERVICE_PORT=8000
AI_SERVICE_URL=http://127.0.0.1:8000
AI_SERVICE_RELOAD=false
AI_SERVICE_PROXY_CHAT=true
AI_SERVICE_PROXY_TIMEOUT_MS=30000
# AI_SERVICE_PYTHON_PATH=./ai_service/venv/Scripts/python.exe

# ── Database ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/dentacare?appName=Cluster0

# ── MongoDB Atlas Vector Search ───────────────────────────────────────────────
ATLAS_VECTOR_INDEX=knowledge_vector_index
ATLAS_VECTOR_PATH=embedding
ATLAS_VECTOR_CANDIDATES=100
RAG_TOP_K=5
RAG_MIN_SCORE=0
RAG_KEYWORD_SCAN_LIMIT=200

# ── JWT ───────────────────────────────────────────────────────────────────────
# JWT
JWT_SECRET=your_jwt_secret_here_min_32_chars
JWT_REFRESH_SECRET=your_refresh_token_secret_min_32_chars
JWT_EXPIRES_IN=7d

# ── Google Gemini AI (used by Python AI service) ──────────────────────────────
# Gemini AI
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_CHAT_MODELS=gemini-2.5-flash,gemini-2.0-flash
GEMINI_EMBEDDING_MODEL=embedding-001
EMBEDDING_PROVIDER=gemini

# Nodemailer (Email)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your_email@gmail.com
MAIL_PASS=your_gmail_app_password
MAIL_FROM="DentaCare <your_email@gmail.com>"

# Client URL (CORS)
CLIENT_URL=http://localhost:5173

# Google OAuth
GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com

# Default Admin Account
ADMIN_EMAIL=admin@dentacare.com
ADMIN_PASSWORD=Admin@123456
ADMIN_NAME=Super Admin
ADMIN_PHONE=0900000000
